# Copy to .env and adjust as needed.
# Source before running the harness to send traces to the local stack.
#
# Usage:
#   cp .env.observability.example .env
#   source .env

# OTLP endpoint — where the harness sends spans.
# Points to Tempo in the local Docker Compose stack.
SPORE_OTLP_ENDPOINT=http://localhost:4317

# Optional: workspace path for Alloy to watch.
# Defaults to the repo root. Set to your project workspace if different.
# SPORE_WORKSPACE=/path/to/your/workspace
