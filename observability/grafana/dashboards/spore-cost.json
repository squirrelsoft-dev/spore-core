{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["spore"],
  "title": "Spore — Cost",
  "uid": "spore-cost",
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Cumulative spend (range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_cost_usd [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Avg cost / session (range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`session` | unwrap attributes_total_cost_usd [$__range])) / sum(count_over_time({job=\"spore-sessions\"} | json | kind=`session` [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Cost of failed sessions (range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`session` | attributes_outcome=`failure` | unwrap attributes_total_cost_usd [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Spend rate over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_cost_usd [$__interval]))",
          "legendFormat": "USD / interval"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Token consumption breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_input_tokens [$__interval]))",
          "legendFormat": "input"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_output_tokens [$__interval]))",
          "legendFormat": "output"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_cache_read_tokens [$__interval]))",
          "legendFormat": "cache read"
        },
        {
          "refId": "D",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`turn` | unwrap attributes_cache_write_tokens [$__interval]))",
          "legendFormat": "cache write"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "stacking": { "mode": "normal" }, "fillOpacity": 30 } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Cost per session by outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (attributes_outcome) (sum_over_time({job=\"spore-sessions\"} | json | kind=`session` | unwrap attributes_total_cost_usd [$__interval]))",
          "legendFormat": "{{attributes_outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "points", "pointSize": 6 } }, "overrides": [] }
    }
  ]
}
