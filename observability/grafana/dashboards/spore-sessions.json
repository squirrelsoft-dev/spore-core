{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["spore"],
  "title": "Spore — Sessions",
  "uid": "spore-sessions",
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Sessions (total in range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"spore-sessions\"} | json | kind=`session` [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "id": 2,
      "title": "Success rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(count_over_time({job=\"spore-sessions\"} | json | kind=`session` | attributes_outcome=`success` [$__range])) / sum(count_over_time({job=\"spore-sessions\"} | json | kind=`session` [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 } ] } }, "overrides": [] }
    },
    {
      "id": 3,
      "title": "Sensor halts (total in range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`session` | unwrap attributes_sensor_halts [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Total turns (range)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "queryType": "instant",
          "expr": "sum(sum_over_time({job=\"spore-sessions\"} | json | kind=`session` | unwrap attributes_total_turns [$__range]))"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] }
    },
    {
      "id": 5,
      "title": "Session outcomes over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (attributes_outcome) (count_over_time({job=\"spore-sessions\"} | json | kind=`session` [$__interval]))",
          "legendFormat": "{{attributes_outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } }, "overrides": [] }
    },
    {
      "id": 6,
      "title": "Turns per session over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "max_over_time({job=\"spore-sessions\"} | json | kind=`session` | unwrap attributes_total_turns [$__interval])",
          "legendFormat": "turns"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "points", "pointSize": 6 } }, "overrides": [] }
    },
    {
      "id": 7,
      "title": "Recent session records",
      "type": "logs",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "enableLogDetails": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"spore-sessions\"} | json | kind=`session`"
        }
      ]
    },
    {
      "id": 8,
      "title": "Trace explorer (Tempo)",
      "type": "table",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceqlSearch",
          "query": "{}",
          "limit": 50,
          "tableType": "traces"
        }
      ]
    }
  ]
}
