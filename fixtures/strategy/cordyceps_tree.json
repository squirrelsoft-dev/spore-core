{
  "kind": "ralph",
  "inner": {
    "kind": "plan_execute",
    "plan": {
      "kind": "react",
      "budget": { "kind": "per_loop", "value": 4 },
      "agent": "planner",
      "toolset": "plan-tools",
      "output": "plan-schema"
    },
    "execute": {
      "kind": "self_verifying",
      "inner": {
        "kind": "react",
        "budget": { "kind": "per_loop", "value": 12 },
        "agent": "executor",
        "toolset": "exec-tools",
        "output": "worker-schema"
      },
      "evaluator": "exec-evaluator"
    }
  },
  "agent": "ralph-agent"
}
