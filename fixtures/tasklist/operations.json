[
  {
    "name": "add_two_then_progress_and_complete",
    "steps": [
      {
        "action": {"action": "add_task", "description": "first"},
        "expected": {
          "ok": true,
          "added": 1,
          "list": {
            "tasks": [{"id": 1, "description": "first", "status": "pending", "blockers": []}],
            "next_id": 2
          }
        }
      },
      {
        "action": {"action": "add_task", "description": "second"},
        "expected": {
          "ok": true,
          "added": 2,
          "list": {
            "tasks": [
              {"id": 1, "description": "first", "status": "pending", "blockers": []},
              {"id": 2, "description": "second", "status": "pending", "blockers": []}
            ],
            "next_id": 3
          }
        }
      },
      {
        "action": {"action": "list_tasks"},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [
              {"id": 1, "description": "first", "status": "pending", "blockers": []},
              {"id": 2, "description": "second", "status": "pending", "blockers": []}
            ],
            "next_id": 3
          }
        }
      },
      {
        "action": {"action": "update_task", "id": 1, "status": "in_progress"},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [
              {"id": 1, "description": "first", "status": "in_progress", "blockers": []},
              {"id": 2, "description": "second", "status": "pending", "blockers": []}
            ],
            "next_id": 3
          }
        }
      },
      {
        "action": {"action": "update_task", "id": 2, "description": "second (edited)"},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [
              {"id": 1, "description": "first", "status": "in_progress", "blockers": []},
              {"id": 2, "description": "second (edited)", "status": "pending", "blockers": []}
            ],
            "next_id": 3
          }
        }
      },
      {
        "action": {"action": "complete_task", "id": 1},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [
              {"id": 1, "description": "first", "status": "completed", "blockers": []},
              {"id": 2, "description": "second (edited)", "status": "pending", "blockers": []}
            ],
            "next_id": 3
          }
        }
      }
    ]
  },
  {
    "name": "errors_do_not_mutate",
    "steps": [
      {
        "action": {"action": "add_task", "description": "task"},
        "expected": {
          "ok": true,
          "added": 1,
          "list": {
            "tasks": [{"id": 1, "description": "task", "status": "pending", "blockers": []}],
            "next_id": 2
          }
        }
      },
      {
        "action": {"action": "complete_task", "id": 99},
        "expected": {"ok": false, "error": "task_not_found"}
      },
      {
        "action": {"action": "complete_task", "id": 1},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [{"id": 1, "description": "task", "status": "completed", "blockers": []}],
            "next_id": 2
          }
        }
      },
      {
        "action": {"action": "update_task", "id": 1, "status": "in_progress"},
        "expected": {"ok": false, "error": "invalid_transition"}
      },
      {
        "action": {"action": "list_tasks"},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [{"id": 1, "description": "task", "status": "completed", "blockers": []}],
            "next_id": 2
          }
        }
      }
    ]
  },
  {
    "name": "add_with_valid_blockers",
    "steps": [
      {
        "action": {"action": "add_task", "description": "build"},
        "expected": {
          "ok": true,
          "added": 1,
          "list": {
            "tasks": [{"id": 1, "description": "build", "status": "pending", "blockers": []}],
            "next_id": 2
          }
        }
      },
      {
        "action": {"action": "add_task", "description": "test", "blockers": [1]},
        "expected": {
          "ok": true,
          "added": 2,
          "list": {
            "tasks": [
              {"id": 1, "description": "build", "status": "pending", "blockers": []},
              {"id": 2, "description": "test", "status": "pending", "blockers": [1]}
            ],
            "next_id": 3
          }
        }
      },
      {
        "action": {"action": "add_task", "description": "ship", "blockers": [1, 2]},
        "expected": {
          "ok": true,
          "added": 3,
          "list": {
            "tasks": [
              {"id": 1, "description": "build", "status": "pending", "blockers": []},
              {"id": 2, "description": "test", "status": "pending", "blockers": [1]},
              {"id": 3, "description": "ship", "status": "pending", "blockers": [1, 2]}
            ],
            "next_id": 4
          }
        }
      }
    ]
  },
  {
    "name": "self_block_rejected_does_not_mutate",
    "steps": [
      {
        "action": {"action": "add_task", "description": "a", "blockers": [1]},
        "expected": {"ok": false, "error": "invalid_blockers"}
      },
      {
        "action": {"action": "list_tasks"},
        "expected": {
          "ok": true,
          "list": {"tasks": [], "next_id": 1}
        }
      }
    ]
  },
  {
    "name": "unknown_blocker_rejected_does_not_mutate",
    "steps": [
      {
        "action": {"action": "add_task", "description": "a"},
        "expected": {
          "ok": true,
          "added": 1,
          "list": {
            "tasks": [{"id": 1, "description": "a", "status": "pending", "blockers": []}],
            "next_id": 2
          }
        }
      },
      {
        "action": {"action": "add_task", "description": "b", "blockers": [99]},
        "expected": {"ok": false, "error": "invalid_blockers"}
      },
      {
        "action": {"action": "list_tasks"},
        "expected": {
          "ok": true,
          "list": {
            "tasks": [{"id": 1, "description": "a", "status": "pending", "blockers": []}],
            "next_id": 2
          }
        }
      }
    ]
  }
]
