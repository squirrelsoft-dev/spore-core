        "keep_architectural_decisions": true,
        "keep_open_problems": true,
        "keep_current_task_state": true,
        "keep_recent_file_list": true,
        "keep_thinking_blocks": true
      },
      "task_instruction": "Refactor the parser module",
      "expected": {
        "passed": true,
        "missing_items": []
      }
    },
    {
