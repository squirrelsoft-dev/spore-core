{
  "description": "Cross-language consistency fixture for KeyTermVerifier (issues #29, #47). Each case builds a SessionState from `task_instruction` plus the optional structured fields `open_problems` (array), `architectural_decisions` (array), `recent_files` (array), `reasoning_summary` (string) — all default to empty when absent, so pre-#47 cases stay byte-valid. The verifier runs KeyTermVerifier::verify against `summary` with the given `hints`, and asserts `passed` and `missing_items` (normalized, lowercased, first-occurrence order). Term extraction: lowercase the source, split on runs of [^a-z0-9], drop tokens shorter than 4 chars, dedupe preserving first-occurrence order. Sources are collected per enabled hint in this fixed order (pins first-occurrence dedup): 1) keep_current_task_state -> task_instruction, 2) keep_open_problems -> each open_problems element, 3) keep_architectural_decisions -> each architectural_decisions element, 4) keep_recent_file_list -> each recent_files element, 5) keep_thinking_blocks -> reasoning_summary. ASCII only.",
  "cases": [
    {
      "name": "full_pass_all_terms_present",
      "summary": "We will refactor the parser module to be faster.",
      "hints": {
        "keep_architectural_decisions": true,
        "keep_open_problems": true,
        "keep_current_task_state": true,
        "keep_recent_file_list": true,
        "keep_thinking_blocks": true
      },
      "task_instruction": "Refactor the parser module",
      "expected": {
        "passed": true,
        "missing_items": []
      }
    },
    {
      "name": "single_miss",
      "summary": "We will refactor the parser.",
      "hints": {
        "keep_architectural_decisions": false,
        "keep_open_problems": false,
        "keep_current_task_state": true,
        "keep_recent_file_list": false,
        "keep_thinking_blocks": false
      },
      "task_instruction": "Refactor the parser module",
      "expected": {
        "passed": false,
        "missing_items": ["module"]
      }
    },
