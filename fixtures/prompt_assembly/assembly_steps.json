{
  "description": "Cross-language consistency fixture for the PromptAssemblyEngine assembly step (ContextSourcesBuilder::assemble) (issue #79). Each case carries `registered_chunks` (in registration order), an `assembly_context`, and the expected chunk-id lists in each stability bucket after assembly. A chunk is included when its `condition` evaluates true AND its `tool_affinity` AND `agent_affinity` gates pass. A chunk whose `triggers` match the incoming message is forced into the per_turn bucket regardless of its declared stability (R13); otherwise the bucket follows the chunk's `stability`. Covers R10 (bucketing), R11 (registration order within a bucket), R12 (tool-affinity 4-way matrix), R13 (trigger -> per_turn), R14 (OnEvent -> per_turn only when pending), R16 (cache_breakpoint preserved), R17 (inactive tool yields no chunk). The `Custom` condition variant is intentionally excluded (decision A3). Each PromptChunk requires `id`, `content`, `stability`; `condition` defaults to {\"type\":\"always\"}, `triggers`/`tool_affinity`/`agent_affinity`/`cache_breakpoint` default to empty/none/false. `active_capabilities` is an array of [tool, capability] pairs.",
  "cases": [
    {
      "name": "r10_r11_bucketing_and_order",
      "registered_chunks": [
        { "id": "s1", "content": "static one", "stability": "static" },
        { "id": "ps1", "content": "session one", "stability": "per_session" },
        { "id": "s2", "content": "static two", "stability": "static" },
        { "id": "pt1", "content": "turn one", "stability": "per_turn" },
        { "id": "ps2", "content": "session two", "stability": "per_session" }
      ],
      "assembly_context": {
        "session_id": "s1", "task_id": "t1", "turn_number": 1,
        "mode": "safe_auto", "phase": "execution"
      },
      "expected_static": ["s1", "s2"],
      "expected_per_session": ["ps1", "ps2"],
      "expected_per_turn": ["pt1"]
    },
    {
      "name": "r12_tool_affinity_tool_and_cap_active",
      "registered_chunks": [
        {
          "id": "bash-git", "content": "git guide", "stability": "static",
          "tool_affinity": { "tool_name": "bash", "capability": "git" }
        }
      ],
      "assembly_context": {
        "session_id": "s1", "task_id": "t1", "turn_number": 1,
        "mode": "safe_auto", "phase": "execution",
        "active_tool_names": ["bash"],
        "active_capabilities": [["bash", "git"]]
