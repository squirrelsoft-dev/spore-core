# Search backend endpoint for the research worker's `web_search` tool. REQUIRED —
# the example exits with a clear error (exit code 2, same as example 06) if unset.
#
# Only the RESEARCH worker uses web_search, but the orchestrator cannot do its job
# without it, so the example fails fast at startup. `web_search` issues
# GET <endpoint>?q=<query> and returns the JSON response body to the worker
# verbatim. The GET path preserves any query string already on the endpoint, so a
# SearXNG JSON API works out of the box: point it at the SearXNG `/search`
# endpoint with `?format=json`, and the tool appends `&q=<query>`.
#
# SearXNG setup: enable the JSON output format in your SearXNG `settings.yml`
# (`search: formats: [html, json]`), restart SearXNG, then set the endpoint below.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by ALL THREE agents (orchestrator, research
# worker, writing worker). Each agent gets its OWN fresh model instance from this
# id — they are genuinely independent and do not share a model object. Default:
# llama3.2.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
