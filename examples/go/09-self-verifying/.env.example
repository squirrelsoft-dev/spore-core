# Override the Ollama model id used by the example (default: llama3.2).
# A larger HOSTED model (or a stronger local coder model such as
# qwen2.5-coder:7b) gives a much cleaner SelfVerifying demo: small models
# mis-judge as the evaluator and may exhaust the loop without a PASS.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# Verify -> revise cap (default: 3). The CLI flag --max-iterations wins over
# this; both are visible in the startup banner and each iteration header.
SPORE_MAX_ITERATIONS=3
