# Search backend endpoint for the `web_search` tool. REQUIRED — the example
# exits with a clear error if this is unset.
#
# `web_search` issues GET <endpoint>?q=<query> and returns the JSON response body
# to the agent verbatim. The GET path preserves any query string already on the
# endpoint, so a SearXNG JSON API works out of the box: point it at the SearXNG
# `/search` endpoint with `?format=json`, and the tool appends `&q=<query>`.
#
# SearXNG setup: enable the JSON output format in your SearXNG `settings.yml`
# (`search: formats: [html, json]`), restart SearXNG, then set the endpoint below.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by the example (default: llama3.2).
# A larger HOSTED model gives a cleaner PlanExecute demo: the planner must emit
# strict JSON, and small local models often garble it.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
