# Override the Ollama model id used by BOTH the build agent (writing the README)
# and the judge model (scoring it). Default: llama3.2.
#
# HONESTY NOTE: HillClimbing against a small local model is genuinely noisy. The
# judge re-scores a freeform README every iteration, so its three sub-scores can
# wobble by a point or two for an UNCHANGED draft — which the keep/revert logic
# then reads as "improvement" or "regression". Expect some thrash; the strategy
# is still doing exactly what it promises (keep the best score seen, revert the
# rest). A larger hosted model gives steadier scores and a cleaner climb.
#
# KNOWN-GOOD: the maintainer has verified `gemma4:31b-cloud` (an Ollama *cloud*
# model) gives a steadier demo — and because it is served through Ollama it needs
# NO code change, just set the value below to it. `llama3.2` is the key-free local
# default. See the README's "Rough edges" section.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# Maximum climbing iterations before the budget halts the loop (default: 6).
# This maps to BudgetLimits.MaxTurns — it is the BUDGET ceiling, NOT a success
# condition. The loop may also halt EARLIER on stagnation (MaxStagnation
# consecutive non-improvements). The CLI flag --max-iterations overrides this.
SPORE_MAX_ITERATIONS=6
