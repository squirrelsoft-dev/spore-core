# Override the Ollama model id used by BOTH the build agent and the evaluator
# agent (default: llama3.2).
#
# HONESTY NOTE: SelfVerifying is demanding. The build agent must produce a
# complete, correct TypeScript function AND save it with a tool, and the
# evaluator must read it back and judge five criteria precisely. Small local
# models routinely mis-judge (false PASS or false FAIL) or never converge.
#
# KNOWN-GOOD: the maintainer has verified `gemma4:31b-cloud` (an Ollama *cloud*
# model) gives a clean SelfVerifying demo — and because it's served through
# Ollama it needs NO code change, just set the value below to it. `llama3.2` is
# the key-free local default. See the README's "Rough edges" section.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# Maximum verify->revise iterations before the loop exhausts (default: 3).
# The CLI flag --max-iterations overrides this.
SPORE_MAX_ITERATIONS=3
