# REQUIRED. SearXNG JSON endpoint for the research worker's `web_search` tool.
# The query is issued as `GET <endpoint>?q=<query>` and the JSON body is returned
# to the agent verbatim (same wiring as example 06). The example exits with code
# 2 if this is unset.
#
#   export SPORE_WEB_SEARCH_ENDPOINT="http://localhost:8888/search?format=json"
SPORE_WEB_SEARCH_ENDPOINT=

# Override the Ollama model id used by ALL THREE agents — orchestrator, research
# worker, and writing worker. Each agent gets its OWN model instance constructed
# from this id (they do not share one object). Default: llama3.2.
#
# A larger/cloud model (e.g. `gemma4:31b-cloud`, served through Ollama with no
# code change) plans and writes more reliably. `llama3.2` is the key-free local
# default. The --model CLI flag overrides this.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
