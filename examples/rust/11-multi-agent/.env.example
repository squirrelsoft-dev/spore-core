# Search backend endpoint for the research worker's `web_search` tool. REQUIRED
# — the example exits if this is unset, exactly like example 06.
#
# `web_search` issues `GET <endpoint>?q=<query>` and returns the JSON response
# body to the agent verbatim. This example targets a self-hosted SearXNG JSON
# endpoint: the `format=json` selector rides on the endpoint URL and the query is
# appended as `&q=<query>`. Enable the JSON format in SearXNG first (see README).
#
# ONLY the research worker gets `web_search`. The writing worker and the
# orchestrator never touch the network — that asymmetry is the point: each agent
# has exactly the tools its job requires, and nothing more.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by ALL THREE agents — the orchestrator, the
# research worker, and the writing worker each get their OWN fresh model instance
# constructed from this id (they are genuinely independent; they do not share a
# model object). Default: llama3.2.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
