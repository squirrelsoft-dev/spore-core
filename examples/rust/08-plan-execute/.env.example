# Search backend endpoint for the `web_search` tool. REQUIRED — the example
# exits if this is unset.
#
# `web_search` issues `GET <endpoint>?q=<query>` and returns the JSON response
# body to the agent verbatim. This example targets a self-hosted SearXNG JSON
# endpoint: the `format=json` selector rides on the endpoint URL and the query is
# appended as `&q=<query>`. Enable the JSON format in SearXNG first (see README).
#
# HONESTY NOTE: raw Brave / Tavily would need a custom auth header
# (`X-Subscription-Token` / `Authorization`). That IS now supported via the
# `WebSearchConfig::auth_headers` field added in core issue #108
# (https://github.com/squirrelsoft-dev/spore-core/issues/108), but this example
# targets keyless SearXNG and configures no auth.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by the example (default: llama3.2).
# A larger HOSTED model gives a cleaner PlanExecute demo: the planner must emit
# strict JSON, and small local models often garble it.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
