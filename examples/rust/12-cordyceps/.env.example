# spore-core example 12 — cordyceps. Copy to `.env` and adjust, or export these.

# The model backing all three composed-tree agents (planner / executor /
# ralph-agent). Run gemma4:e4b OR BETTER — small models (e.g. llama3.2 3B)
# narrate tool use instead of emitting tool calls. Default: gemma4:e4b.
SPORE_OLLAMA_MODEL=gemma4:e4b

# Override the Ollama endpoint (default: http://localhost:11434). Every node
# agent rides this one endpoint.
SPORE_OLLAMA_BASE_URL=http://localhost:11434
