# spore-core example 12 — cordyceps. Copy to `.env` and adjust, or export these.

# The model backing all three composed-tree agents (planner / executor /
# ralph-agent). Run gemma4:e4b OR BETTER — small models (e.g. llama3.2 3B)
# narrate tool use instead of emitting tool calls. Default: gemma4:e4b.
SPORE_OLLAMA_MODEL=gemma4:e4b

# Override the Ollama endpoint (default: http://localhost:11434). Every node
# agent AND both consult handlers ride this one endpoint.
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# The #114 `advice` consult handler runs a heterogeneous (near-frontier, cloud)
# advisor model with read_file/grep. Default: minimax-m3:cloud.
SPORE_ADVISOR_MODEL=minimax-m3:cloud

# The #114 `research` consult handler web-searches via a SearXNG JSON endpoint.
# REQUIRED — the example fails fast at startup if unset (like examples 06/11).
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json
