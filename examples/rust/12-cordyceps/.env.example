# spore-core example 12 — cordyceps. Copy to `.env` and adjust, or export these.

# Orchestrator + analysis/research workers model. Run gemma4:e4b OR BETTER —
# small models (e.g. llama3.2 3B) narrate tool use instead of emitting tool
# calls, which would masquerade as a different failure than the consult ladder
# is meant to handle. Default: gemma4:e4b.
SPORE_OLLAMA_MODEL=gemma4:e4b

# The advisor model (the `kind=advice` consult handler). A near-frontier cloud
# model by default; rides the SAME Ollama endpoint as everything else (only the
# model id differs). Set to a local model if you have no cloud account.
# Default: minimax-m3:cloud.
SPORE_ADVISOR_MODEL=minimax-m3:cloud

# Search backend for the research worker's `web_search` tool (the `kind=research`
# consult handler). REQUIRED — the example exits if unset, exactly like 06/11.
# Points at a self-hosted SearXNG JSON endpoint; the query is appended as
# `&q=<query>`. Enable the JSON format in SearXNG first (see README).
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama endpoint (default: http://localhost:11434). All agents —
# orchestrator, workers, and the cloud advisor — ride this one endpoint.
SPORE_OLLAMA_BASE_URL=http://localhost:11434
