# spore-core example 12 — cordyceps. Copy to `.env` and adjust, or export these.

# The model backing the coding agent. Run gemma4:e4b OR BETTER — small models
# (e.g. llama3.2 3B) narrate tool use instead of emitting tool calls, so they
# never act. Default: gemma4:e4b. Override per-run with `--model <id>`.
SPORE_OLLAMA_MODEL=gemma4:e4b

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# The workspace root the agent reads/writes (read-write sandbox). Defaults to the
# directory you launch from; override here or with `--workspace <path>`.
# SPORE_WORKSPACE=/path/to/project
