# Search backend endpoint for the `web_search` tool. REQUIRED — the example
# exits if this is unset.
#
# `web_search` issues `GET <endpoint>?q=<query>` and returns the JSON response
# body to the agent verbatim. Point this at a self-hosted SearXNG JSON endpoint:
# its API is `GET /search?q=<query>&format=json`, so include `?format=json` here
# — the GET path PRESERVES that query string and appends `q=<query>`. (#108 added
# the configurable GET method / query param this relies on.)
#
# Enable JSON in SearXNG first (settings.yml: `search: formats: [html, json]`),
# then restart it. See the README "SearXNG setup" section.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by the example (default: llama3.2).
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
