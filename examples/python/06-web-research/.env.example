# Search backend endpoint for the `web_search` tool. REQUIRED — the example
# exits if this is unset.
#
# `web_search` POSTs the query to this URL as JSON `{ "query": ... }` and returns
# the JSON response body to the agent verbatim. Any endpoint that accepts that
# request shape works: a self-hosted SearXNG JSON endpoint, or a small mock you
# run locally for the demo.
#
# HONESTY NOTE: raw Brave / Tavily are NOT yet drop-in here. They require a
# custom auth header (`X-Subscription-Token` / `Authorization`) that the current
# `web_search` tool does not send. That gap is tracked as core issue #108
# (https://github.com/squirrelsoft-dev/spore-core/issues/108). Until #108 lands,
# point this at a SearXNG JSON endpoint or a `{ "query" }`-compatible mock.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search

# Override the Ollama model id used by the example (default: llama3.2).
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
