# Override the Ollama model id used by the example (default: llama3.2).
# The evaluator must judge code against five criteria and end with exactly `PASS`
# or `FAIL: <reason>`; small local models often mis-judge or drift off-format and
# the loop exhausts.
#
# KNOWN-GOOD: the maintainer has verified `gemma4:31b-cloud` (an Ollama *cloud*
# model) gives a clean SelfVerifying demo — and because it's served through
# Ollama it needs NO code change, just set the value below to it. `llama3.2` is
# the key-free local default; a stronger coder model (e.g. qwen2.5-coder:7b) also
# helps. See the README's "Rough edges" section.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434

# Verify -> revise cap. CLI flag --max-iterations wins over this; default 3.
# Visible at startup and in every iteration header.
SPORE_MAX_ITERATIONS=3
