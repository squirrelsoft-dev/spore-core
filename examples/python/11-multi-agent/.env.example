# Search backend endpoint for the research worker's `web_search` tool. REQUIRED
# — the example exits with code 2 if this is unset (same as example 06). Only the
# research worker uses it, but the orchestrator cannot do its job without it, so
# the example fails fast at startup.
#
# `web_search` issues `GET <endpoint>?q=<query>` and returns the JSON response
# body to the agent verbatim. Point this at a self-hosted SearXNG JSON endpoint:
# its API is `GET /search?q=<query>&format=json`, so include `?format=json` here
# — the GET path PRESERVES that query string and appends `q=<query>`.
#
# Enable JSON in SearXNG first (settings.yml: `search: formats: [html, json]`),
# then restart it. See the README "SearXNG setup" section in example 06.
SPORE_WEB_SEARCH_ENDPOINT=http://localhost:8888/search?format=json

# Override the Ollama model id used by ALL THREE agents (research worker, writing
# worker, orchestrator). Each agent gets its OWN fresh model instance — they do
# not share a model object. Default: llama3.2.
SPORE_OLLAMA_MODEL=llama3.2

# Override the Ollama endpoint (default: http://localhost:11434).
SPORE_OLLAMA_BASE_URL=http://localhost:11434
